// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model City {
  id        String    @id
  name      String
  stations  Station[]
}

model Station {
  id        String   @id
  name      String
  x         Float
  y         Float
  lines     String   // Comma separated lines
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  outgoing  Connection[] @relation("FromStation")
  incoming  Connection[] @relation("ToStation")
}

model Connection {
  id            Int      @id @default(autoincrement())
  fromId        String
  toId          String
  distance      Float    @default(0) // distance in km
  cost          Float    @default(0) // fare cost
  stops         Int      @default(1) // number of stops between stations
  fromStation   Station  @relation("FromStation", fields: [fromId], references: [id])
  toStation     Station  @relation("ToStation", fields: [toId], references: [id])
}

model SearchHistory {
  id          Int      @id @default(autoincrement())
  source      String
  destination String
  timestamp   DateTime @default(now())
}
